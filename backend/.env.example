# Copy to .env and adjust (optional for local dev — defaults work with Next on :3000)
#
# --- LLM: pick one ---
# anthropic = Claude API (needs ANTHROPIC_API_KEY)
# ollama    = your machine, open-weights model (install https://ollama.com )
LLM_PROVIDER=anthropic

ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# When LLM_PROVIDER=ollama (no Anthropic key required):
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# OLLAMA_MODEL=llama3.2

# Agent (Anthropic): tool calling + RAG. Set 0 to disable tools (plain completion).
# AGENT_TOOLS=1

# Supabase / Postgres — leave unset to use backend/db.sqlite3 locally
# DATABASE_URL=postgresql://USER:PASS@HOST:5432/postgres?sslmode=require

# Twilio (optional — for send_sms_nudge tool + check_in_nudges command)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=1
# 0.0.0.0 allows opening http://0.0.0.0:8000/ in the browser when using runserver 0.0.0.0:8000
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost,0.0.0.0
CORS_ALLOWED_ORIGINS=http://127.0.0.1:3000,http://localhost:3000
CSRF_TRUSTED_ORIGINS=http://127.0.0.1:3000,http://localhost:3000
